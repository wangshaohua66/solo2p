{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=pottery_studio.db"
  },
  "Jwt": {
    "Secret": "YourSuperSecretKeyForJWTTokenGenerationMustBeAtLeast32CharactersLong",
    "Issuer": "PotteryStudio",
    "Audience": "PotteryStudioUsers",
    "AccessTokenExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 7
  },
  "AppSettings": {
    "UploadPath": "Uploads",
    "MaxFileSizeMB": 8,
    "ThumbnailWidth": 400,
    "DefaultPageSize": 20,
    "MaxPageSize": 100,
    "MembershipExpiryWarningDays": 14,
    "DailyCleanupHour": 3,
    "LogRetentionDays": 30,
    "MaxConcurrentAdmins": 10
  }
}
