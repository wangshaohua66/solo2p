ENV=development

ENCRYPTION_KEY=your-32-byte-aes-256-encryption-key-here

CAPTCHA_API_KEY=your-captcha-solving-service-api-key
CAPTCHA_SERVICE=2captcha

TRANSLATION_API_KEY=your-translation-service-api-key
TRANSLATION_SERVICE=google

DATABASE_PATH=./data/cpla.db
COOKIE_STORE_PATH=./data/cookies.json

LOG_LEVEL=info
LOG_DIR=./logs

MAX_BROWSERS_PER_PLATFORM=3
HEADLESS=true
BROWSER_TIMEOUT=30000

CIRCUIT_BREAKER_FAILURE_THRESHOLD=0.3
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=300000

MAX_RETRIES=3
RETRY_INITIAL_DELAY=2
RETRY_MAX_DELAY=60

STATUS_SYNC_CRON=0 */2 * * *
