@{
    ViewData["Title"] = "照片墙";
    ViewData["Breadcrumb"] = "回忆墙";
}

<section class="ch-filter-bar">
    <div class="ch-filter-group">
        <span class="ch-filter-label">来源</span>
        <span class="ch-pill active" data-filter="all">全部照片</span>
        <span class="ch-pill" data-filter="mine">我的上传</span>
    </div>
    <div class="ch-filter-group">
        <span class="ch-filter-label">活动</span>
        <select class="form-select form-select-sm" id="photoEventFilter" style="min-width:200px;border-radius:999px;">
            <option value="">-- 全部活动 --</option>
        </select>
    </div>
    <div class="ch-filter-group">
        <span class="ch-filter-label">时间</span>
        <select class="form-select form-select-sm" id="photoTimeFilter" style="border-radius:999px;">
            <option value="">全部时间</option>
            <option value="7">近7天</option>
            <option value="30">近30天</option>
            <option value="90">近3个月</option>
            <option value="365">近一年</option>
        </select>
    </div>
    <div class="ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-outline-primary btn-sm" id="reloadPhotosBtn">
            <i class="bi bi-arrow-clockwise me-1"></i>刷新
        </button>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal">
            <i class="bi bi-cloud-upload me-1"></i>上传照片
        </button>
    </div>
</section>

<section id="photoTrackSection" class="d-none mb-4">
    <div class="card p-4">
        <h5 class="mb-3"><i class="bi bi-geo-alt me-2 text-ch-accent"></i>活动当天 GPS 轨迹</h5>
        <div id="photoTrackMap" class="bg-ch-primary-50 rounded-3 d-flex align-items-center justify-content-center"
             style="height:280px;color:var(--ch-primary);">
            <div class="text-center">
                <i class="bi bi-map fs-1 d-block mb-2 opacity-40"></i>
                <small>可接入百度/高德地图API绘制轨迹热力图</small>
            </div>
        </div>
        <div id="photoTrackPoints" class="mt-3"></div>
    </div>
</section>

<section class="position-relative">
    <div class="ch-photo-grid ch-anim-up" id="photoGrid">
        <div class="ch-loading-overlay position-absolute w-100 h-100 d-flex align-items-center justify-content-center">
            <div class="spinner-border text-ch-primary"></div>
        </div>
    </div>
    <div id="photoMoreWrap" class="text-center mt-4 d-none">
        <button class="btn btn-outline-primary" id="loadMorePhotosBtn">
            <i class="bi bi-chevron-double-down me-1"></i>加载更多
        </button>
    </div>
</section>

<div class="ch-photo-lightbox" id="photoLightbox">
    <button class="ch-lightbox-close" id="lightboxClose" aria-label="关闭">
        <i class="bi bi-x-lg"></i>
    </button>
    <button class="ch-lightbox-nav ch-lightbox-prev" id="lightboxPrev" aria-label="上一张">
        <i class="bi bi-chevron-left"></i>
    </button>
    <img class="ch-lightbox-image" id="lightboxImage" src="" alt="" />
    <button class="ch-lightbox-nav ch-lightbox-next" id="lightboxNext" aria-label="下一张">
        <i class="bi bi-chevron-right"></i>
    </button>
    <div class="ch-lightbox-meta" id="lightboxMeta"></div>
</div>

@section Scripts {
    <script src="/js/pages/photos.js"></script>
}
