@{
    var current = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "Home";
    var action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "Index";
    var isActive = (string ctrl, string act = "Index") =>
        string.Equals(current, ctrl, StringComparison.OrdinalIgnoreCase) &&
        (act == "*" || string.Equals(action, act, StringComparison.OrdinalIgnoreCase));
}
<aside class="ch-sidebar" id="chSidebar">
    <div class="ch-sidebar-brand">
        <i class="bi bi-tree-fill"></i>
        <span>CampHub</span>
    </div>

    <ul class="ch-nav">
        <li>
            <a href="/" class="@(isActive("Home") ? "active" : "")">
                <i class="bi bi-house-door"></i>
                <span>首页仪表盘</span>
            </a>
        </li>

        <li class="ch-nav-section">活动管理</li>
        <li>
            <a href="/Event" class="@(isActive("Event", "*") ? "active" : "")">
                <i class="bi bi-calendar-event"></i>
                <span>我的活动</span>
            </a>
        </li>
        <li>
            <a href="/Event/Create">
                <i class="bi bi-plus-square"></i>
                <span>发起活动</span>
            </a>
        </li>

        <li class="ch-nav-section">装备中心</li>
        <li>
            <a href="/Gear" class="@(isActive("Gear", "Index") ? "active" : "")">
                <i class="bi bi-backpack2"></i>
                <span>装备库</span>
            </a>
        </li>
        <li>
            <a href="/Gear/Create" class="@(isActive("Gear", "Create") ? "active" : "")">
                <i class="bi bi-plus-circle"></i>
                <span>添加装备</span>
            </a>
        </li>

        <li class="ch-nav-section">回忆</li>
        <li>
            <a href="/Photo" class="@(isActive("Photo") ? "active" : "")">
                <i class="bi bi-images"></i>
                <span>照片墙</span>
            </a>
        </li>
        <li>
            <a href="/Stats" class="@(isActive("Stats") ? "active" : "")">
                <i class="bi bi-bar-chart-line"></i>
                <span>统计分析</span>
            </a>
        </li>
    </ul>

    <div class="ch-sidebar-footer dropdown" data-bs-toggle="dropdown">
        <div id="nav-user-info">
            <div class="spinner-border spinner-border-sm text-white-50"></div>
            <span class="ms-2 small text-white-50">加载中...</span>
        </div>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="min-width:200px;">
            <li><h6 class="dropdown-header fw-bold text-muted small" style="letter-spacing:.08em;">账户</h6></li>
            <li><a class="dropdown-item" href="/Stats"><i class="bi bi-trophy me-2 text-ch-accent"></i>我的信用分</a></li>
            <li><a class="dropdown-item" href="/Gear"><i class="bi bi-box-seam me-2 text-ch-primary"></i>我的装备</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="javascript:;" id="logout-btn">
                <i class="bi bi-box-arrow-right me-2"></i>退出登录
            </a></li>
        </ul>
    </div>
</aside>
